<header class="page-hero" style="border-bottom:var(--grid-border-light)">
  <p class="eyebrow page-hero__eyebrow">FAQ</p>
  <h1 class="title-large page-hero__title" style="color:var(--cream-ink)">{{ section.settings.title }}</h1>
</header>

<div class="faq-grid" style="color:var(--cream-ink); border-bottom:var(--grid-border-light)">
  {%- for block in section.blocks -%}
    <div class="faq-row" style="border-bottom-color:rgba(23, 20, 16, 0.15)" {{ block.shopify_attributes }}>
      <div class="faq-question">
        <h2>{{ block.settings.question }}</h2>
        <span class="faq-icon">+</span>
      </div>
      <div class="faq-answer">
        <p>{{ block.settings.answer }}</p>
      </div>
    </div>
  {%- endfor -%}
</div>

<script>
  document.querySelectorAll(".faq-row").forEach(row => {
    row.addEventListener("click", () => {
      const isOpen = row.classList.contains("is-open");
      
      document.querySelectorAll(".faq-row").forEach(r => {
        if (r !== row) {
          r.classList.remove("is-open");
        }
      });
      
      row.classList.toggle("is-open", !isOpen);
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Accordion Page",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Questions, answered."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question Text",
          "default": "What is a solid perfume?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer Text",
          "default": "A wax-based fragrance you swipe on instead of spray. Take Me Out is a 5g solid perfume stick: alcohol free, skin-nourishing, and small enough to live in your pocket."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "faq_item", "settings": { "question": "What is a solid perfume?", "answer": "A wax-based fragrance you swipe on instead of spray. Take Me Out is a 5g solid perfume stick: alcohol free, skin-nourishing, and small enough to live in your pocket." } },
      { "type": "faq_item", "settings": { "question": "How do I apply it?", "answer": "Slide open the sleeve cover, pull the stick out, swipe it on pulse points: wrists, neck, behind the ears. Reapply whenever you want. No spray, no cloud, no asking the room's permission." } },
      { "type": "faq_item", "settings": { "question": "Is it unisex?", "answer": "Yes. Every CH24 product is designed for everyone. It is built into the foundation of the brand, not a per-product choice." } }
    ]
  }
}
{% endschema %}

<section class="pw">
  <div class="pw__media">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1800 }}" alt="" loading="eager" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
    {%- else -%}
      <img src="{{ 'hero-lineup.jpg' | asset_url }}" alt="" loading="eager" width="1800" height="2250">
    {%- endif -%}
    <div class="pw__scrim" aria-hidden="true"></div>
  </div>

  <div class="pw__content">
    <a class="pw__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <img src="{{ 'logo-white.png' | asset_url }}" alt="{{ shop.name }}" width="90" height="52">
    </a>

    <p class="pw__eyebrow">{{ section.settings.eyebrow | upcase }}</p>
    <h1 class="pw__title">{{ section.settings.heading }}</h1>
    <p class="pw__sub">{{ section.settings.subheading }}</p>

    {%- form 'storefront_password', class: 'pw__form' -%}
      {%- if form.errors -%}
        <p class="pw__error" role="alert">{{ form.errors.messages['form'] | default: "That password didn't work. Try again." }}</p>
      {%- endif -%}
      <div class="pw__field">
        <label class="visually-hidden" for="pw-password">Password</label>
        <input type="password" name="password" id="pw-password" placeholder="Enter store password" required autofocus>
        <button class="btn btn--orange" type="submit">Enter</button>
      </div>
    {%- endform -%}

    {%- if section.settings.footnote != blank -%}
      <p class="pw__footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>

  <footer class="pw__footer">
    <p>© {{ 'now' | date: '%Y' }} {{ shop.name }} · BUILT IN INDIA. BUILT FOR NOW.</p>
    <div class="pw__footer-links">
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener">Instagram</a>
      {%- endif -%}
      {%- if settings.whatsapp_number != blank -%}
        <a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'hi CH24 —' | url_param_escape }}" target="_blank" rel="noopener">WhatsApp</a>
      {%- endif -%}
    </div>
  </footer>
</section>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Defaults to the hero lineup photo if none is chosen."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "INDIA'S 1ST GEN Z FRAGRANCE HOUSE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Something's brewing."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take Me Out is a 5g solid perfume stick in a flip-top box. Pocket perfume, launching soon."
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote (below the form)",
      "default": "Know the password? Enter above."
    }
  ],
  "presets": [
    {
      "name": "Password Page"
    }
  ]
}
{% endschema %}

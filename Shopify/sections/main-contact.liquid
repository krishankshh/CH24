<article class="page">
  <header class="page-hero">
    <p class="page-hero__eyebrow">CONTACT</p>
    <h1 class="page-hero__title">{{ section.settings.title }}</h1>
    <p class="page-hero__sub">{{ section.settings.description }}</p>
  </header>

  <div class="contact-grid">
    <div class="contact-card">
      <h2>{{ section.settings.wa_card_title }}</h2>
      <p>{{ section.settings.wa_card_desc }}</p>
      <a class="btn btn--orange" data-wa-cta href="#" target="_blank" rel="noopener">{{ section.settings.wa_btn_label }}</a>
      
      {%- if section.settings.email_address != blank -%}
        <h2 style="margin-top:2rem">Email</h2>
        <p><a href="mailto:{{ section.settings.email_address }}" style="color:var(--orange)">{{ section.settings.email_address }}</a></p>
      {%- endif -%}
    </div>

    <form class="contact-card" data-contact-form>
      <h2>{{ section.settings.form_title }}</h2>
      <div class="form-field">
        <label for="cname">Name</label>
        <input id="cname" name="name" type="text" required>
      </div>
      <div class="form-field">
        <label for="cmsg">Message</label>
        <textarea id="cmsg" name="message" required></textarea>
      </div>
      <button class="btn btn--orange" type="submit">{{ section.settings.form_btn_label }}</button>
    </form>
  </div>
</article>

<script>
  // Dynamically map WhatsApp values from global settings configuration in layout
  const CH24_WA_CONTACT = "{{ settings.whatsapp_number | default: '919196036665' }}";

  document.querySelector("[data-wa-cta]").href =
    `https://wa.me/${CH24_WA_CONTACT}?text=${encodeURIComponent("hi CH24 —")}`;

  document.querySelector("[data-contact-form]").addEventListener("submit", (e) => {
    e.preventDefault();
    const f = new FormData(e.target);
    const msg = `hi CH24 — I'm ${f.get("name")}. ${f.get("message")}`;
    window.open(`https://wa.me/${CH24_WA_CONTACT}?text=${encodeURIComponent(msg)}`, "_blank", "noopener");
  });
</script>

{% schema %}
{
  "name": "Contact Page Layout",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Talk to us."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Page Subtitle Description",
      "default": "Order help, scent questions, collabs. We reply as people, not as a ticket queue."
    },
    {
      "type": "header",
      "content": "WhatsApp Floater Card"
    },
    {
      "type": "text",
      "id": "wa_card_title",
      "label": "WhatsApp Card Title",
      "default": "WhatsApp"
    },
    {
      "type": "text",
      "id": "wa_card_desc",
      "label": "WhatsApp Card Description",
      "default": "Fastest way to reach us. Tap, type, done."
    },
    {
      "type": "text",
      "id": "wa_btn_label",
      "label": "WhatsApp CTA Button Label",
      "default": "Message on WhatsApp"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Contact Email Address",
      "default": "help@ch24.in"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title Header",
      "default": "Or write it here"
    },
    {
      "type": "text",
      "id": "form_btn_label",
      "label": "Form Submit Button Label",
      "default": "Send message"
    }
  ]
}
{% endschema %}
